{
  "name": "refine-rbac-template",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"react-devtools\" \"refine dev\"",
    "build": "refine build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc -b",
    "commitlint": "commitlint --edit",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "cross-env PLAYWRIGHT_DOWNLOAD_HOST=https://registry.npmmirror.com/-/binary/playwright playwright install chromium",
    "serve": "refine serve",
    "prepare": "husky",
    "docker:build": "docker build -t refine-rbac-template .",
    "docker:run": "docker run -p 8080:80 refine-rbac-template",
    "preinstall": "npx only-allow pnpm",
    "update": "refine update",
    "check": "npx npm-check"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
