    "vite-plugin-mock-dev-server": "^2.1.1",
    "vite-plugin-pwa": "^1.2.0"
  },
  "packageManager": "pnpm@10.26.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  }
