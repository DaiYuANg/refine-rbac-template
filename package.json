    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query": "^5.96.2",
    "axios": "^1.14.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dayjs": "^1.11.20",
    "framer-motion": "^12.38.0",
    "i18next": "^25.10.10",
    "i18next-browser-languagedetector": "^8.2.1",
    "lodash-es": "^4.18.1",
    "lucide-react": "^1.7.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.1",
    "react-i18next": "^16.6.6",
    "react-router-dom": "^7.14.0",
    "recharts": "^3.8.1",
    "shadcn": "^4.1.2",
    "sonner": "^2.0.7",
    "spark-md5": "^3.0.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
