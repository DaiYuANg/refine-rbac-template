engine-strict=true
store-dir=.pnpm-store
PLAYWRIGHT_DOWNLOAD_HOST=https://registry.npmmirror.com/-/binary/playwright
# Playwright browser download: 浏览器不走 npm，需用环境变量。
# pnpm test:e2e:install 已内置 npmmirror 国内源。
# 手动安装时: PLAYWRIGHT_DOWNLOAD_HOST=https://registry.npmmirror.com/-/binary/playwright pnpm exec playwright install chromium