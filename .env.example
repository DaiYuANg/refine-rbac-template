# API base URL for data provider
# VITE_API_URL=/api

# Auth refresh endpoint (default: ${VITE_API_URL}/auth/refresh)
# VITE_AUTH_REFRESH_URL=/api/auth/refresh

# Use vite-plugin-mock-dev-server mock API (dev: auto true; set true to enable mock in production build)
# VITE_USE_MOCK=true

# Enable Refine audit log provider (default: off)
# VITE_ENABLE_AUDIT_LOG=true

# Mock: 401 probability for testing (set 0 in E2E for stable tests)
# VITE_MOCK_401_PROB=0.15

# Mock: health check failure rate (set 0 in E2E)
# VITE_MOCK_HEALTH_FAIL_PROB=0.05
